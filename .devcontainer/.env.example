# License key for Advanced Custom Fields PRO WordPress plugin.
MUNICIPIO_ACF_PRO_KEY=
# GitHub token with permission to read packages.
MUNICIPIO_GITHUB_TOKEN=

# Migration Script Configuration
# Remote server SSH connection
SSH_PORT=3022
REMOTE_SSH=ubuntu@example.com
REMOTE_PATH=/var/www/prod

# Remote site details
REMOTE_SITE_PROTOCOL=https://
# Supports a single domain value, comma-separated values, or a bash array.
# Examples:
# REMOTE_SITE_DOMAIN=example.com
# REMOTE_SITE_DOMAIN=example.com,example-two.com
# REMOTE_SITE_DOMAIN=("example.com" "example-two.com")
REMOTE_SITE_DOMAIN=example.com
REMOTE_PREFIX=wp_
CDN_DOMAIN=

# Local site configuration
# Supports a single slug value, comma-separated values, or a bash array.
# If array/list is used, the item count must match REMOTE_SITE_DOMAIN.
# Examples:
# LOCAL_SITE_SLUG=mysite
# LOCAL_SITE_SLUG=mysite,mysite-two
# LOCAL_SITE_SLUG=("mysite" "mysite-two")
LOCAL_SITE_SLUG=mysite